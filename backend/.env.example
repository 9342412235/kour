# Server
NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177
API_URL=http://localhost:4000

# PostgreSQL
DATABASE_URL=postgresql://postgres:Star@localhost:5432/thekour
PGSSL=false

# Auth / JWT
JWT_SECRET=thekour_jwt_secret_2026
JWT_EXPIRES_IN=7d
COOKIE_NAME=thekour_token
SESSION_SECRET=thekour_session_secret_2026

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Admin seed account (used once by `npm run seed:admin`) — there is one
# Admin role on this platform, with full access including Staff Accounts
# and Company Settings.
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=Admin@123
# OTP expiry (minutes)
OTP_EXPIRES_MIN=10
RESET_TOKEN_EXPIRES_MIN=30

# ─────────────────────────────────────────────────────────────────────────────
# SMTP — Nodemailer (Gmail App Password recommended)
# ─────────────────────────────────────────────────────────────────────────────
# To send real emails (forgot-password OTPs, low-stock alerts, etc.):
#
#   Gmail setup (free, no domain needed):
#     1. Enable 2-Step Verification on your Gmail account.
#     2. Go to: myaccount.google.com → Security → 2-Step Verification → App passwords
#     3. Click "Create" → choose "Mail" → copy the 16-character code.
#     4. Paste it (no spaces) as SMTP_PASS below.
#     IMPORTANT: use the App Password, NOT your normal Gmail login password.
#
#   Leave SMTP_PASS empty to run in dev-mode — OTPs are printed to the
#   server console so you can test without a real inbox.
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your.gmail@gmail.com
SMTP_PASS=                         # 16-char Gmail App Password
SMTP_FROM="The Kour <your.gmail@gmail.com>"

# Automatic backup cron schedule
# '0 2 * * *' = daily at 2 AM | '0 * * * *' = every hour | '0 2 * * 0' = weekly
BACKUP_CRON=0 2 * * *
